# ----------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ----------------------------------------------------------------

# The canonical URL of the deployed site (no trailing slash).
# Used in sitemap.xml, robots.txt, OG tags, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---- Google AdSense ----
# Your AdSense publisher ID, e.g. ca-pub-1234567890123456
# Get it from https://adsense.google.com/start/
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# ---- Local development: GFG solutions path ----
# Clone the GFG repo locally and point this to its solutions/ folder:
#   git clone https://github.com/cvalingam/GeeksforGeeks.git ../gfg-solutions
# Then set:
# GFG_SOLUTIONS_DIR=../gfg-solutions/solutions
# Leave unset on Vercel — vercel.json buildCommand clones the repo automatically.
# Create a token at https://vercel.com/account/tokens
VERCEL_TOKEN=

# Found in .vercel/project.json after running `vercel link` inside website/
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
